   "source": [
    "import cv2\n",
    "\n",
    "# read webcam\n",
    "webcam = cv2.VideoCapture(0)\n",
    "\n",
    "# visualize webcam\n",
    "while True:\n",
    "  ret, frame = webcam.read()\n",
    "  cv2.imshow('frame', frame)\n",
    "  cv2.waitKey(33)\n",
    "\n",
    "  if cv2.waitKey(1) == ord('q'):\n",
    "    break\n",
    "\n",
    "webcam.release()\n",
    "cv2.destroyAllWindows()\n",
    "cv2.waitKey(1)"
   ]
  }
 ],
