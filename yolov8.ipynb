    "from ultralytics import YOLO\n",
    "\n",
    "# Load a pretrained YOLO8n model\n",
    "model = YOLO(\"yolov8n.pt\")\n",
    "\n",
    "# Run inference on the source\n",
    "# generator of Results objects\n",
    "results = model(source=0, show=True) \n",
    "\n",
    "print(results)"
